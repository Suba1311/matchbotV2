# MatchBot V2 — environment configuration.
# Copy to .env and adjust. Never commit a real .env.

# --- Database ----------------------------------------------------------------
# Point at your existing local Postgres or the shared AWS RDS instance.
DATABASE_URL=postgresql://localhost:5432/matchbot

# Single schema for now; selected purely by this variable. No schema name is
# hardcoded in the code. Change this (and re-run `matchbot init-db`) to use a
# different schema/environment later.
DB_SCHEMA=public

# Optional: a separate connection for the read-only Member Universe.
# Defaults to DATABASE_URL when unset.
# MEMBER_UNIVERSE_URL=postgresql://localhost:5432/matchbot

# --- Runtime -----------------------------------------------------------------
# local | fargate | glue | snowflake
MATCHBOT_RUNTIME=local

# --- Paths -------------------------------------------------------------------
MATCHBOT_CONFIG_DIR=config

# --- Logging -----------------------------------------------------------------
MATCHBOT_LOG_LEVEL=INFO
# true -> JSON logs (prod / CloudWatch); false -> human-readable console (dev)
MATCHBOT_LOG_JSON=false
